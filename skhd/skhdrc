# change focus (vim ctrl - w + hjkl)
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east
alt - h : yabai -m window --focus west

# swap windows within the space
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east
shift + alt - h : yabai -m window --swap west
ctrl + shift + alt - j : yabai -m window --warp south
ctrl + shift + alt - k : yabai -m window --warp north
ctrl + shift + alt - l : yabai -m window --warp east
ctrl + shift + alt - h : yabai -m window --warp west

# put windows into other spaces
shift + alt - 1 : yabai -m window --space 1 --focus
shift + alt - 2 : yabai -m window --space 2 --focus
shift + alt - 3 : yabai -m window --space 3 --focus
shift + alt - 4 : yabai -m window --space 4 --focus
shift + alt - 5 : yabai -m window --space 5 --focus
shift + alt - 6 : yabai -m window --space 6 --focus
shift + alt - 7 : yabai -m window --space 7 --focus
shift + alt - 8 : yabai -m window --space 8 --focus
shift + alt - 9 : yabai -m window --space 9 --focus

# switch to other space
ctrl + alt + cmd + shift - 1 : yabai -m space --focus 1
ctrl + alt + cmd + shift - 2 : yabai -m space --focus 2
ctrl + alt + cmd + shift - 3 : yabai -m space --focus 3
ctrl + alt + cmd + shift - 4 : yabai -m space --focus 4
ctrl + alt + cmd + shift - 5 : yabai -m space --focus 5
ctrl + alt + cmd + shift - 6 : yabai -m space --focus 6

# window management
alt - space : yabai -m window --toggle zoom-fullscreen
alt - f : yabai -m window --toggle float
ctrl + cmd + alt + shift - b: yabai -m space --layout bsp
ctrl + cmd + alt + shift - f: yabai -m space --layout stack

# creating & switching spaces, focusing display 
#ctrl + alt + cmd + shift - l : if [[ $(yabai -m query --spaces --display | jq '.[-1]."has-focus"') == "false" ]]; then yabai -m space --focus next; fi
#ctrl + alt + cmd + shift - h : if [[ $(yabai -m query --spaces --display | jq '.[0]."has-focus"') == "false" ]]; then yabai -m space --focus prev; fi
ctrl + alt + cmd + shift - space : yabai -m display --focus recent
ctrl + alt + cmd + shift - s : yabai -m space --create
ctrl + alt + cmd + shift - d : yabai -m space --destroy
ctrl + alt + cmd + shift - 0x18 : yabai -m space --balance #(equal sign)

# reload config
ctrl + alt + cmd - r : yabai --restart-service

